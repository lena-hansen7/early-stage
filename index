<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The Early Stage — AI Demo Day at MIT</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
      background: #fff;
      color: #000;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      overflow: hidden;
    }

    main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 4rem 2rem;
      gap: 2.8rem;
      position: relative;
    }

    /* spotlight canvas sits behind everything */
    #spotlight-canvas {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .icon {
      opacity: 0;
      transition: opacity 0.6s ease;
      position: relative;
      z-index: 1;
    }
    .icon.show { opacity: 1; }

    .wordmark-wrap {
      position: relative;
      z-index: 1;
    }

    .wordmark {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(32px, 6.5vw, 68px);
      letter-spacing: -0.02em;
      white-space: nowrap;
      min-height: 1.2em;
    }

    .black { color: #000; }

    /* STAGE starts black, transitions to red when spotlight hits */
    #part-after {
      color: #000;
      transition: color 0.4s ease;
    }
    #part-after.lit { color: #D7160F; }

    .cursor {
      display: inline-block;
      width: 0.12em;
      height: 0.85em;
      background: #000;
      vertical-align: text-bottom;
      margin-left: 3px;
      animation: blink 1s step-end infinite;
      transition: background 0.3s ease;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0; }
    }

    .body-line {
      font-size: 17px;
      font-weight: 300;
      color: #555;
      text-align: center;
      line-height: 1.9;
      max-width: 420px;
      opacity: 0;
      transition: opacity 0.6s ease;
      position: relative;
      z-index: 1;
    }
    .body-line.show { opacity: 1; }

    .info {
      font-size: 14px;
      font-weight: 300;
      color: #888;
      text-align: center;
      line-height: 1.8;
      max-width: 400px;
      letter-spacing: 0.01em;
      opacity: 0;
      transition: opacity 0.6s ease 0.2s;
      position: relative;
      z-index: 1;
    }
    .info.show { opacity: 1; }

    footer {
      border-top: 1px solid #ebebeb;
      padding: 1.4rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
      position: relative;
      z-index: 1;
    }

    .footer-copy { font-size: 11px; color: #ccc; }

    .cta {
      font-family: 'Syne', sans-serif;
      font-size: clamp(13px, 1.6vw, 18px);
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: #000;
      color: #fff;
      border: none;
      padding: 18px 48px;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: opacity 0.15s;
      opacity: 0;
      position: relative;
      z-index: 1;
    }
    .cta.show { opacity: 1; }
    .cta:hover { opacity: 0.7; }

    footer {
      border-top: 1px solid #ebebeb;
      padding: 1rem;
      position: relative;
      z-index: 1;
    }

    .sponsors {
      opacity: 0;
      transition: opacity 0.8s ease 0.4s;
      text-align: center;
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 860px;
    }
    .sponsors.show { opacity: 1; }

    .sponsors-label {
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #ccc;
      margin-bottom: 1.4rem;
    }

    .sponsors-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 3rem;
      flex-wrap: wrap;
    }

    .sponsor-logo {
      height: 28px;
      width: auto;
      max-width: 120px;
      object-fit: contain;
      filter: grayscale(100%) opacity(0.45);
      transition: filter 0.2s ease;
    }
    .sponsor-logo:hover {
      filter: grayscale(0%) opacity(0.85);
    }
    .sponsor-logo--mit {
      height: 48px;
    }
  </style>
</head>
<body>

  <canvas id="spotlight-canvas"></canvas>

  <main>
    <svg class="icon" id="icon" width="52" height="52" viewBox="0 0 120 130" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <!-- black badge background -->
      <rect x="0" y="0" width="120" height="130" rx="10" fill="#000"/>
      <!-- E — vertical stroke -->
      <rect x="10" y="18" width="7" height="68" fill="#fff"/>
      <!-- E — top bar -->
      <rect x="17" y="18" width="32" height="8" fill="#fff" rx="1"/>
      <!-- E — mid bar (white, behind node) -->
      <rect x="17" y="50" width="22" height="8" fill="#fff" rx="1"/>
      <!-- E — bottom bar -->
      <rect x="17" y="78" width="32" height="8" fill="#fff" rx="1"/>
      <!-- red node at end of midbar — the spotlight source -->
      <circle cx="42" cy="54" r="10" fill="#D7160F"/>
      <circle cx="42" cy="54" r="15" fill="none" stroke="#D7160F" stroke-width="1.5" opacity="0.35"/>
      <!-- beam angles down-right from node toward S -->
      <polygon points="42,64 62,108 100,108" fill="#D7160F" opacity="0.18"/>
      <line x1="42" y1="64" x2="62" y2="108" stroke="#D7160F" stroke-width="1" opacity="0.5"/>
      <line x1="42" y1="64" x2="100" y2="108" stroke="#D7160F" stroke-width="1" opacity="0.5"/>
      <!-- S — lit red by beam -->
      <text x="88" y="106" text-anchor="middle" font-family="'Helvetica Neue', Arial, sans-serif" font-weight="800" font-size="52" fill="#D7160F">S</text>
      <!-- stage floor line -->
      <line x1="0" y1="116" x2="120" y2="116" stroke="#fff" stroke-width="5"/>
    </svg>

    <div class="wordmark-wrap">
      <div class="wordmark" id="wordmark" aria-label="The Early Stage">
        <span class="black" id="part-before"></span><span id="part-after"></span><span class="cursor" id="cur"></span>
      </div>
    </div>

    <p class="body-line" id="body">
      The stage for the earliest &amp; boldest AI founders.
    </p>

    <p class="info" id="info">
      If you're building something consequential, come demo it on The Early Stage.
    </p>

    <a href="#" class="cta" id="cta">Apply to Demo</a>

    <div class="sponsors" id="sponsors">
      <p class="sponsors-label">Supported by</p>
      <div class="sponsors-row">
        <img src="data:image/png;base64," alt="Engine Ventures" class="sponsor-logo" style="mix-blend-mode: multiply;">
        <img src="data:image/png;base64," alt="MIT" class="sponsor-logo sponsor-logo--mit" style="mix-blend-mode: multiply;">
        <img src="data:image/jpeg;base64," alt="Link Ventures" class="sponsor-logo" style="mix-blend-mode: multiply;">
        <img src="data:image/jpeg;base64," alt="E14 Fund" class="sponsor-logo" style="mix-blend-mode: multiply;">
        <img src="data:image/webp;base64," alt="Underscore VC" class="sponsor-logo" style="mix-blend-mode: multiply;">
      </div>
    </div>
  </main>

  <footer></footer>

  <script>
    // ── Canvas spotlight ──────────────────────────────────────
    const canvas = document.getElementById('spotlight-canvas');
    const ctx = canvas.getContext('2d');

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    // Spotlight state
    const spot = {
      // source: top-left corner to start, sweeps to above STAGE
      srcX: -80,
      srcY: 0,
      // target: where beam points on page (updated to STAGE position)
      targetX: window.innerWidth * 0.5,
      targetY: window.innerHeight * 0.5,
      angle: 0,           // current beam angle in radians
      targetAngle: 0,     // angle we're sweeping to
      spread: 0.18,       // cone half-angle
      length: window.innerHeight * 1.4,
      opacity: 0,
      active: false,
    };

    function drawSpotlight() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      if (!spot.active || spot.opacity <= 0) return;

      const sx = spot.srcX;
      const sy = spot.srcY;
      const ang = spot.angle;
      const spread = spot.spread;
      const len = spot.length;

      // two edge rays of the cone
      const l1x = sx + Math.cos(ang - spread) * len;
      const l1y = sy + Math.sin(ang - spread) * len;
      const l2x = sx + Math.cos(ang + spread) * len;
      const l2y = sy + Math.sin(ang + spread) * len;

      // radial gradient from source
      const grad = ctx.createRadialGradient(sx, sy, 0, sx, sy, len);
      grad.addColorStop(0,   `rgba(215, 22, 15, ${0.22 * spot.opacity})`);
      grad.addColorStop(0.4, `rgba(215, 22, 15, ${0.10 * spot.opacity})`);
      grad.addColorStop(1,   `rgba(215, 22, 15, 0)`);

      ctx.beginPath();
      ctx.moveTo(sx, sy);
      ctx.lineTo(l1x, l1y);
      // arc at the far end
      ctx.arc(sx, sy, len, ang - spread, ang + spread);
      ctx.lineTo(sx, sy);
      ctx.closePath();
      ctx.fillStyle = grad;
      ctx.fill();

      // source dot
      ctx.beginPath();
      ctx.arc(sx, sy, 6, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(215, 22, 15, ${spot.opacity})`;
      ctx.fill();

      // soft halo
      ctx.beginPath();
      ctx.arc(sx, sy, 14, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(215, 22, 15, ${0.25 * spot.opacity})`;
      ctx.fill();
    }

    let animFrame;
    let sweeping = false;
    let sweepStart = null;
    const SWEEP_DURATION = 1400; // ms

    function sweepTo(tx, ty, onDone) {
      // compute angle from source to target word
      const dx = tx - spot.srcX;
      const dy = ty - spot.srcY;
      spot.targetAngle = Math.atan2(dy, dx);
      const startAngle = spot.angle;
      sweepStart = null;
      sweeping = true;

      function step(ts) {
        if (!sweepStart) sweepStart = ts;
        const p = Math.min((ts - sweepStart) / SWEEP_DURATION, 1);
        // ease in-out cubic
        const e = p < 0.5 ? 4*p*p*p : 1 - Math.pow(-2*p+2,3)/2;
        spot.angle = startAngle + (spot.targetAngle - startAngle) * e;
        spot.opacity = Math.min(spot.opacity + 0.03, 1);
        drawSpotlight();
        if (p < 1) {
          animFrame = requestAnimationFrame(step);
        } else {
          sweeping = false;
          if (onDone) onDone();
        }
      }
      animFrame = requestAnimationFrame(step);
    }

    // ── Typewriter ─────────────────────────────────────────────
    const full = "THE EARLY STAGE";
    const splitAt = full.indexOf("STAGE");
    const before = document.getElementById('part-before');
    const after  = document.getElementById('part-after');
    const cur    = document.getElementById('cur');

    let i = 0;

    function getStageCenter() {
      // get bounding rect of the #part-after span once STAGE is typed
      const rect = after.getBoundingClientRect();
      return {
        x: rect.left + rect.width / 2,
        y: rect.top + rect.height / 2,
      };
    }

    function startSpotlight() {
      // source: top-left of viewport
      spot.srcX = 40;
      spot.srcY = 20;
      // initial angle pointing vaguely left/down before sweep
      spot.angle = Math.atan2(window.innerHeight * 0.3, -window.innerWidth * 0.5);
      spot.opacity = 0.01;
      spot.active = true;
      drawSpotlight();
    }

    function typeStage(onDone) {
      if (i < full.length) {
        const ch = full[i];
        after.textContent += ch;
        i++;
        const delay = 80 + Math.random() * 60;
        setTimeout(() => typeStage(onDone), delay);
      } else {
        cur.style.background = '#D7160F';
        if (onDone) onDone();
      }
    }

    function typeEarly(onDone) {
      if (i < splitAt) {
        const ch = full[i];
        before.textContent += ch;
        i++;
        const delay = ch === ' ' ? 120 : 80 + Math.random() * 60;
        setTimeout(() => typeEarly(onDone), delay);
      } else {
        if (onDone) onDone();
      }
    }

    // ── Sequence ───────────────────────────────────────────────
    // 1. Icon fades in + spotlight source appears
    // 2. "THE EARLY " types
    // 3. Spotlight sweeps to where STAGE will be
    // 4. "STAGE" types as the beam lands — letters turn red
    // 5. Body copy fades in

    setTimeout(() => {
      document.getElementById('icon').classList.add('show');
      startSpotlight();

      setTimeout(() => {
        typeEarly(() => {
          // pause briefly, then sweep
          setTimeout(() => {
            // estimate STAGE center — it's roughly right-center of wordmark
            const wm = document.getElementById('wordmark').getBoundingClientRect();
            const stageTargetX = wm.right - wm.width * 0.22;
            const stageTargetY = wm.top + wm.height * 0.5;

            sweepTo(stageTargetX, stageTargetY, () => {
              // beam has landed — now type STAGE and light it up
              typeStage(() => {
                after.classList.add('lit');
                cur.style.background = '#D7160F';
                setTimeout(() => {
                  document.getElementById('body').classList.add('show');
                  document.getElementById('info').classList.add('show');
                  document.getElementById('cta').classList.add('show');
                  document.getElementById('sponsors').classList.add('show');
                }, 400);
              });
            });
          }, 300);
        });
      }, 600);
    }, 400);
  </script>

</body>
</html>
